{
  "name": "cronus-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Cronus JS/TS workspace — desktop app (Tauri) and shared UI (React).",
  "packageManager": "pnpm@11.13.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check --write .",
    "format": "biome format --write .",
    "fallow": "fallow",
    "fallow:fix": "fallow fix",
    "audit": "fallow audit",
    "audit:ci": "fallow audit --format json",
    "audit:review": "fallow review --brief",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fallow": "^3.7.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  }
}