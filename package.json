{
  "name": "cronus-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Cronus JS/TS workspace — desktop app (Tauri) and shared UI (React).",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fallow": "fallow",
    "fallow:fix": "fallow fix",
    "audit": "fallow audit",
    "audit:ci": "fallow audit --format json",
    "audit:review": "fallow review --brief"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "fallow": "^3.0.0"
  }
}