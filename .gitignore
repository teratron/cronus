*.min.css

# Rust / Cargo (crates/*, apps/desktop/tauri)
target/
debug/
**/*.rs.bk
*.pdb
# Note: Cargo.lock IS committed (workspace ships binaries — reproducible builds).

# Node / pnpm (packages/*, apps/*)
node_modules/
.pnpm-store/
.npm/
*.tsbuildinfo
# Note: pnpm-lock.yaml IS committed (reproducible installs).

# Vite
.vite/
*.timestamp-*.mjs

# Tauri (apps/desktop/tauri)
**/tauri/gen/
# tauri/target is covered by `target/` above.
# Signing keys — never commit.
*.keystore
*.jks
*.p12

# fallow (codebase intelligence) — ignore local cache only; fallow-baselines/ ARE committed.
.fallow/

# Editor backup files
*.bak
*.tmp

.gemini/
gha-creds-*.json

# Local settings
*/settings.json
*/settings.*.json

